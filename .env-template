# SportRadar API
SPORTRADAR_API_KEY=your_sportradar_api_key_here

# Home page defaults for competition/season selection
DEFAULT_COMPETITION_ID=sr:competition:17
DEFAULT_SEASON_ID=sr:season:130281

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Flask session secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your_flask_secret_key_here
